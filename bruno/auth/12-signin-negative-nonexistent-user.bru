meta {
  name: Signin - Negative - Non-existent User
  type: http
  seq: 12
  res.status: 401
}

post {
  url: {{baseUrl}}/auth/signin
  body: json
  auth: none
}

body:json {
  {
    "username": "nonexistentuser12345",
    "password": "{{testPassword}}"
  }
}

assert {
  res.status: 401
  body.message: "@contains:usuario"
}