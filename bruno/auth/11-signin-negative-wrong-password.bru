meta {
  name: Signin - Negative - Wrong Password
  type: http
  seq: 11
  res.status: 401
}

post {
  url: {{baseUrl}}/auth/signin
  body: json
  auth: none
}

body:json {
  {
    "username": "admin",
    "password": "wrongpassword123"
  }
}

assert {
  res.status: 401
  body.message: "@contains:contrase"
}