meta {
  name: Signup - Negative - Duplicate Username
  type: http
  seq: 4
  res.status: 409
}

post {
  url: {{baseUrl}}/auth/signup
  body: json
  auth: none
}

body:json {
  {
    "username": "admin",
    "email": "anotheremail@test.com",
    "password": "{{testPassword}}"
  }
}

assert {
  res.status: 409
  body.message: "@contains:usuario"
}